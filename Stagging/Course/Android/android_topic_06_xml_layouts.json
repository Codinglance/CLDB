{
  "title": "XML Layouts & Views",
  "sections": [
    {
      "type": "text",
      "heading": "What are XML Layouts?",
      "content": "Android UI in the traditional View system is defined using XML layout files inside res/layout/. These files describe a hierarchy of Views (UI elements) and ViewGroups (layout containers). At runtime Android inflates the XML into View objects and displays them on screen. XML keeps UI design separate from Kotlin code."
    },
    {
      "type": "bullet",
      "heading": "Key Concepts",
      "items": [
        "Views are UI elements like TextView, Button, ImageView",
        "ViewGroups arrange Views (LinearLayout, ConstraintLayout)",
        "Layouts are inflated in Activity using setContentView()",
        "Views have attributes like id, width, height, padding",
        "Views can be accessed using findViewById or View Binding"
      ]
    },
    {
      "type": "table",
      "heading": "Width & Height Values",
      "rows": [
        {
          "value": "match_parent",
          "description": "View fills entire parent size"
        },
        {
          "value": "wrap_content",
          "description": "View size fits its content"
        },
        {
          "value": "0dp",
          "description": "Match constraints in ConstraintLayout"
        }
      ]
    },
    {
      "type": "table",
      "heading": "Dimension Units",
      "rows": [
        {
          "unit": "dp",
          "use": "Layout sizes, margins, padding"
        },
        {
          "unit": "sp",
          "use": "Text sizes"
        },
        {
          "unit": "px",
          "use": "Avoid using in layouts"
        }
      ]
    },
    {
      "type": "bullet",
      "heading": "Important View Attributes",
      "items": [
        "android:id – unique identifier for the view",
        "android:layout_width / height – size of the view",
        "android:padding – inner spacing",
        "android:layout_margin – outer spacing",
        "android:background – background color or drawable",
        "android:visibility – visible, invisible, or gone"
      ]
    },
    {
      "type": "table",
      "heading": "Common Android Views",
      "rows": [
        {
          "view": "TextView",
          "purpose": "Displays text"
        },
        {
          "view": "EditText",
