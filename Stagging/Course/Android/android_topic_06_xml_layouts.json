        },
        {
          "view": "Button",
          "purpose": "Clickable action button"
        },
        {
          "view": "ImageView",
          "purpose": "Displays images"
        },
        {
          "view": "CheckBox",
          "purpose": "Selectable option"
        },
        {
          "view": "RecyclerView",
          "purpose": "Efficient scrollable list"
        }
