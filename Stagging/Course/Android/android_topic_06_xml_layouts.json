    },
    {
      "type": "bullet",
      "heading": "TextView Important Attributes",
      "items": [
        "android:text – displayed text",
        "android:textSize – text size in sp",
        "android:textColor – text color",
        "android:gravity – text alignment",
        "android:maxLines – limit text lines"
      ]
    },
    {
      "type": "table",
      "heading": "View Visibility",
      "rows": [
        {
          "visibility": "visible",
          "behavior": "Shown normally"
        },
        {
          "visibility": "invisible",
          "behavior": "Hidden but still takes space"
        },
        {
          "visibility": "gone",
          "behavior": "Hidden and removed from layout"
        }
      ]
    },
    {
      "type": "bullet",
      "heading": "Accessing Views in Kotlin",
      "items": [
        "findViewById() – traditional method",
        "View Binding – modern recommended approach",
        "Enable View Binding in build.gradle",
        "Access views with binding.viewId"
      ]
    },
    {
      "type": "bullet",
      "heading": "Handling Clicks",
      "items": [
        "setOnClickListener { } for click events",
        "Use binding.button.setOnClickListener { }",
        "Avoid android:onClick in XML"
      ]
    },
    {
      "type": "bullet",
      "heading": "Best Practices",
      "items": [
        "Use ConstraintLayout for better performance",
        "Avoid deep nested layouts",
        "Use resources for strings, colors, and dimensions",
        "Use View Binding instead of findViewById"
      ]
    },
    {
      "type": "text",
      "heading": "Summary",
      "content": "XML layouts define the UI structure in Android using Views and ViewGroups. Understanding layout attributes, common Views, and using View Binding allows developers to build clean, maintainable, and responsive Android interfaces."
    }
  ]
